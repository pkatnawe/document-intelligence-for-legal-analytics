# Copy to .env and fill in. Never commit real tokens.
DATABRICKS_HOST=https://dbc-bb185e3a-c061.cloud.databricks.com
DATABRICKS_TOKEN=dapi-your-token-here

# --- Models ---
# Free Edition DISABLES the proprietary models (Gemini/Claude return "rate limit of 0"),
# so the POC uses open-weight models that Free Edition serves. gemma-3-12b is the
# vision-capable one (needed for scanned / garbled-text invoices).
TIER1_MODEL=databricks-gemma-3-12b
TIER2_MODEL=databricks-meta-llama-3-3-70b-instruct
# Production (paid workspace) — same code, just swap these back:
# TIER1_MODEL=databricks-gemini-3-5-flash
# TIER2_MODEL=databricks-claude-opus-4-8

# --- Delta-backed store (Unity Catalog): jobs + audit_events + documents Volume ---
WAREHOUSE_ID=23ebe67c53c1d192
UC_CATALOG=workspace
UC_SCHEMA=invoice_poc

# --- MLflow tracing (model-audit layer). Leave empty to disable remote tracing. ---
MLFLOW_EXPERIMENT=/Users/you@example.com/invoice-extraction

MAX_ATTEMPTS=3
